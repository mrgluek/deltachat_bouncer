# Custom display name for the bot (e.g. "Steward Bot", "Consul Bot", etc.)
# If not set, defaults to "Bouncer Bot"
DISPLAY_NAME=Bouncer Bot

# Custom status message for the bot
# If not set, defaults to the standard inactive user tracking description
STATUS_TEXT=I monitor group activity, manage chat/channel catalogs, welcome new members, and search contacts. Send /help for commands.

# Custom avatar/icon path for the bot (absolute or relative to bot.py)
# If not set, defaults to icon.png in the project directory
# AVATAR_PATH=icon.png
